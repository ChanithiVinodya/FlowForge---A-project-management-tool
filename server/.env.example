# --- Database (native PostgreSQL install, no Docker) ---
DATABASE_URL="postgresql://pmtool_user:pmtool_pass@localhost:5432/pmtool_dev"

# --- Redis (native install) ---
REDIS_URL="redis://localhost:6379"

# --- Auth ---
JWT_ACCESS_SECRET="replace-with-strong-random-secret"
JWT_REFRESH_SECRET="replace-with-different-strong-random-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# --- App ---
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN="http://localhost:5173"

# --- File storage (S3 / R2 compatible) ---
S3_BUCKET="pm-tool-attachments"
S3_REGION="auto"
S3_ENDPOINT=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# --- Email (for notifications / password reset) ---
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
